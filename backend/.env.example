# Copy this file to .env and fill in your values

# App
DEBUG=true

# Database — update with your PostgreSQL credentials
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/compliance_db

# JWT — generate a strong random secret for production
SECRET_KEY=change-me-in-production

# S3 / Object Storage (Supabase Storage, Cloudflare R2, or AWS S3)
S3_BUCKET_NAME=compliance-documents
S3_REGION=af-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Push Notifications
FCM_SERVER_KEY=
